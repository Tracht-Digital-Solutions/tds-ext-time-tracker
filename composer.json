{
  "name": "tracht-digital-solutions/ext-time-tracker",
  "description": "Time-tracker extension (backend Module) for the TDS panel platform.",
  "type": "library",
  "license": "proprietary",
  "version": "0.1.0",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.13",
    "tracht-digital-solutions/panel-contract": "*"
  },
  "repositories": [
    { "type": "path", "url": "../panel-contract" }
  ],
  "autoload": {
    "psr-4": {
      "Tds\\Ext\\TimeTracker\\": "php/src/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  }
}
